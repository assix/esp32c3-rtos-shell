#ifndef CONFIG_H
#define CONFIG_H

// --- Wi-Fi Configuration ---
// Set these before building/flashing.
#define WIFI_SSID      "YOUR_WIFI_SSID"
#define WIFI_PASS      "YOUR_WIFI_PASSWORD"

// Telnet hint: press Ctrl + ] to enter telnet prompt and quit.

// --- Shell / Telnet Access ---
#define SHELL_USER     "admin"
#define SHELL_PASS     "change-me"

// --- Hardware Pins ---
#define I2C_SDA_PIN    5
#define I2C_SCL_PIN    6
#define OLED_ADDR      0x3C
#define STATUS_LED_PIN 8
#define STATUS_LED_ON  1

#endif
